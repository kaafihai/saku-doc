---
import { getCollection } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import { entryToSlug, segmentToLabel } from "../lib/slugUtils";

interface Props {
    title: string;
    description?: string;
    ogImage?: string;
    canonicalUrl?: string;
    noindex?: boolean;
    navIndex: number;
    base: string;
    pubDate?: string | Date;
}

const {
    title,
    description,
    ogImage,
    canonicalUrl,
    noindex,
    navIndex,
    base,
    pubDate,
} = Astro.props;

const currentPath = Astro.url.pathname;
const entries = await getCollection(`blog_${navIndex}` as any);

const sorted = [...entries].sort((a: any, b: any) => {
    const da = a.data.pubDate ? new Date(a.data.pubDate).getTime() : 0;
    const db = b.data.pubDate ? new Date(b.data.pubDate).getTime() : 0;
    return db - da; // newest first
});

type SidebarLink = { label: string; href: string; date?: string };

const navLinks: SidebarLink[] = sorted.map((entry: any) => {
    const href = `/${entryToSlug(entry.id, base)}`;
    const label =
        entry.data.title ??
        segmentToLabel(
            entry.id
                .replace(/\.(md|mdoc)$/, "")
                .split("/")
                .pop()!,
        );
    const date = entry.data.pubDate
        ? new Date(entry.data.pubDate).toLocaleDateString("en-US", {
              year: "numeric",
              month: "short",
              day: "numeric",
          })
        : undefined;
    return { label, href, date };
});

function isActive(href: string): boolean {
    return currentPath === href || currentPath === href + "/";
}

const formattedDate = pubDate
    ? new Date(pubDate).toLocaleDateString("en-US", {
          year: "numeric",
          month: "long",
          day: "numeric",
      })
    : undefined;
---

<BaseLayout
    title={title}
    description={description}
    ogImage={ogImage}
    canonicalUrl={canonicalUrl}
    noindex={noindex}
>
    <slot name="head" slot="head" />
    <nav aria-label="breadcrumb" class="border-bottom bg-body-tertiary"></nav>
    <main>
        <div class="container-md py-4 px-4">
            <ol class="breadcrumb mb-0 small mb-4">
                <li class="breadcrumb-item">
                    <a href={`/${base}`} class="font-monospace">..</a>
                </li>
                <li
                    class="breadcrumb-item active font-monospace"
                    aria-current="page"
                >
                    {title}
                </li>
            </ol>
            <article>
                <header class="mb-4">
                    <h1 class="mb-1">{title}</h1>
                    {
                        formattedDate && (
                            <p class="text-muted small mb-0">{formattedDate}</p>
                        )
                    }
                </header>
                <slot />
            </article>
        </div>
    </main>
</BaseLayout>
