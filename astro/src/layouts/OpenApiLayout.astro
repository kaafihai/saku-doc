---
import BaseLayout from "./BaseLayout.astro";
import {
    METHOD_COLORS,
    STATUS_COLORS,
    statusColor,
    schemaToString,
    type OperationDetail,
    type OperationEntry,
} from "../lib/openapiUtils";

interface Props {
    title: string;
    base: string;
    apiInfo: { title: string; description?: string; version: string } | null;
    apiTags: { name: string; description?: string }[];
    operation: OperationDetail | null;
    allOperations: OperationEntry[];
    fetchError: string | null;
}

const { title, base, apiInfo, apiTags, operation, allOperations, fetchError } =
    Astro.props;

const currentPath = Astro.url.pathname;

// Group sidebar operations by tag
const tagDescriptions = new Map<string, string>();
for (const tag of apiTags) {
    if (tag.description) tagDescriptions.set(tag.name, tag.description);
}

const tagMap = new Map<string, OperationEntry[]>();
const untagged: OperationEntry[] = [];

for (const op of allOperations) {
    if (!op.tags?.length) {
        untagged.push(op);
    } else {
        for (const tag of op.tags) {
            if (!tagMap.has(tag)) tagMap.set(tag, []);
            tagMap.get(tag)!.push(op);
        }
    }
}
if (untagged.length) tagMap.set("Other", untagged);

function opHref(op: OperationEntry): string {
    return `/${base}/${op.slug}`;
}

function isActive(op: OperationEntry): boolean {
    const href = opHref(op);
    return currentPath === href || currentPath === href + "/";
}

const overviewHref = `/${base}`;
const isOverview =
    currentPath === overviewHref || currentPath === overviewHref + "/";
---

<BaseLayout title={title}>
    <div class="d-md-none border-bottom px-3 py-2 bg-body-secondary">
        <button
            class="btn btn-sm btn-outline-secondary"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#api-nav"
            aria-controls="api-nav"
            aria-expanded="false"
        >
            &#9776;
        </button>
    </div>

    <div class="api-layout d-md-flex">
        <nav
            class="collapse d-md-block api-sidebar bg-body-secondary border-end"
            id="api-nav"
            aria-label="API navigation"
        >
            <div class="overflow-y-auto h-100">
                <div class="d-flex flex-column gap-1 p-3">
                    <input
                        id="api-search"
                        type="search"
                        class="form-control form-control-sm mb-1"
                        placeholder="Search endpoints…"
                        autocomplete="off"
                    />
                    <a
                        class:list={[
                            "nav-link py-1 px-2 rounded fw-semibold",
                            isOverview ? "active" : "text-body-secondary",
                        ]}
                        href={overviewHref}
                        aria-current={isOverview ? "page" : undefined}
                    >
                        Overview
                    </a>
                    {
                        Array.from(tagMap.entries()).map(([tag, ops]) => (
                            <div class="mt-2" data-tag-group={tag}>
                                <div class="text-uppercase fw-semibold small text-muted px-2 mb-1">
                                    {tag}
                                </div>
                                {ops.map((op) => (
                                    <a
                                        class:list={[
                                            "nav-link py-1 px-2 rounded d-flex align-items-center gap-2",
                                            isActive(op)
                                                ? "active fw-semibold"
                                                : "text-body-secondary",
                                        ]}
                                        href={opHref(op)}
                                        data-op-slug={op.slug}
                                        aria-current={
                                            isActive(op) ? "page" : undefined
                                        }
                                    >
                                        <span
                                            class:list={[
                                                "badge text-uppercase flex-shrink-0",
                                                `text-bg-${METHOD_COLORS[op.method] ?? "secondary"}`,
                                            ]}
                                            style="min-width: 3rem; text-align: center; font-size: 0.6rem;"
                                        >
                                            {op.method}
                                        </span>
                                        <span class="small text-truncate">
                                            {op.summary ?? op.path}
                                        </span>
                                    </a>
                                ))}
                            </div>
                        ))
                    }
                </div>
            </div>
        </nav>

        <main class="flex-grow-1 overflow-hidden">
            <div class="container-md py-4 px-4">
                {
                    fetchError ? (
                        <div class="alert alert-danger">
                            Failed to load OpenAPI spec: {fetchError}
                        </div>
                    ) : !operation ? (
                        // Overview page
                        <div>
                            <h1 class="mb-1">{apiInfo?.title ?? base}</h1>
                            {apiInfo && (
                                <span class="badge text-bg-secondary rounded-pill me-2">
                                    v{apiInfo.version}
                                </span>
                            )}
                            {apiInfo?.description && (
                                <p class="text-muted mt-3">
                                    {apiInfo.description}
                                </p>
                            )}
                            <p class="text-muted mt-3">
                                Select an endpoint from the sidebar to view its
                                documentation.
                            </p>
                        </div>
                    ) : (
                        // Endpoint detail page
                        <div>
                            <div class="d-flex align-items-center gap-3 mb-2">
                                <span
                                    class:list={[
                                        "badge text-uppercase fw-bold fs-6",
                                        `text-bg-${METHOD_COLORS[operation.method] ?? "secondary"}`,
                                    ]}
                                >
                                    {operation.method}
                                </span>
                                <code class="fs-5 fw-semibold text-body">
                                    {operation.path}
                                </code>
                            </div>

                            {operation.summary && (
                                <h1 class="h3 mb-1">{operation.summary}</h1>
                            )}
                            {operation.operationId && (
                                <p class="text-muted small mb-3">
                                    <code>{operation.operationId}</code>
                                </p>
                            )}
                            {operation.description && (
                                <p class="mb-4">{operation.description}</p>
                            )}

                            {operation.parameters &&
                                operation.parameters.length > 0 && (
                                    <section class="mb-4">
                                        <h2 class="h5 border-bottom pb-2 mb-3">
                                            Parameters
                                        </h2>
                                        <div class="table-responsive">
                                            <table class="table table-sm table-bordered mb-0">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th>Name</th>
                                                        <th>In</th>
                                                        <th>Type</th>
                                                        <th>Required</th>
                                                        <th>Description</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    {operation.parameters.map(
                                                        (param) => (
                                                            <tr>
                                                                <td>
                                                                    <code>
                                                                        {
                                                                            param.name
                                                                        }
                                                                    </code>
                                                                </td>
                                                                <td>
                                                                    <span class="badge text-bg-secondary">
                                                                        {
                                                                            param.in
                                                                        }
                                                                    </span>
                                                                </td>
                                                                <td>
                                                                    <code class="small">
                                                                        {schemaToString(
                                                                            param.schema,
                                                                        )}
                                                                    </code>
                                                                </td>
                                                                <td>
                                                                    {param.required ? (
                                                                        <span class="badge text-bg-danger">
                                                                            yes
                                                                        </span>
                                                                    ) : (
                                                                        <span class="text-muted">
                                                                            no
                                                                        </span>
                                                                    )}
                                                                </td>
                                                                <td class="small text-muted">
                                                                    {param.description ??
                                                                        ""}
                                                                </td>
                                                            </tr>
                                                        ),
                                                    )}
                                                </tbody>
                                            </table>
                                        </div>
                                    </section>
                                )}

                            {operation.requestBody && (
                                <section class="mb-4">
                                    <h2 class="h5 border-bottom pb-2 mb-3">
                                        Request Body
                                        {operation.requestBody.required && (
                                            <span class="badge text-bg-danger ms-2">
                                                required
                                            </span>
                                        )}
                                    </h2>
                                    {operation.requestBody.description && (
                                        <p class="text-muted mb-2">
                                            {operation.requestBody.description}
                                        </p>
                                    )}
                                    {operation.requestBody.content && (
                                        <div class="d-flex flex-wrap gap-1">
                                            {Object.keys(
                                                operation.requestBody.content,
                                            ).map((ct) => (
                                                <code class="badge text-bg-secondary">
                                                    {ct}
                                                </code>
                                            ))}
                                        </div>
                                    )}
                                </section>
                            )}

                            {operation.responses && (
                                <section class="mb-4">
                                    <h2 class="h5 border-bottom pb-2 mb-3">
                                        Responses
                                    </h2>
                                    <div class="d-flex flex-column gap-2">
                                        {Object.entries(
                                            operation.responses,
                                        ).map(([code, resp]) => (
                                            <div class="d-flex align-items-start gap-2">
                                                <span
                                                    class:list={[
                                                        "badge rounded-pill flex-shrink-0",
                                                        `text-bg-${statusColor(code)}`,
                                                    ]}
                                                >
                                                    {code}
                                                </span>
                                                <span class="small text-muted">
                                                    {resp.description ?? ""}
                                                </span>
                                            </div>
                                        ))}
                                    </div>
                                </section>
                            )}
                        </div>
                    )
                }
            </div>
        </main>
    </div>
</BaseLayout>

<script
    src="https://cdn.jsdelivr.net/npm/fuse.js@7.1.0/dist/fuse.min.js"
    is:inline></script>

<script define:vars={{ allOperations }}>
    const input = document.getElementById("api-search");
    if (input && typeof Fuse !== "undefined") {
        const fuse = new Fuse(allOperations, {
            keys: [
                { name: "summary", weight: 2 },
                { name: "path", weight: 1.5 },
                { name: "method", weight: 1 },
                { name: "tags", weight: 0.5 },
            ],
            threshold: 0.35,
            includeMatches: true,
        });

        input.addEventListener("input", () => {
            const query = input.value.trim();

            const opLinks = document.querySelectorAll("[data-op-slug]");
            const tagGroups = document.querySelectorAll("[data-tag-group]");

            if (!query) {
                opLinks.forEach((el) => el.classList.remove("d-none"));
                tagGroups.forEach((el) => el.classList.remove("d-none"));
                return;
            }

            const matchingSlugs = new Set(
                fuse.search(query).map((r) => r.item.slug),
            );

            opLinks.forEach((el) => {
                el.classList.toggle(
                    "d-none",
                    !matchingSlugs.has(el.dataset.opSlug),
                );
            });

            tagGroups.forEach((group) => {
                const hasVisible = group.querySelector(
                    "[data-op-slug]:not(.d-none)",
                );
                group.classList.toggle("d-none", !hasVisible);
            });
        });
    }
</script>

<style>
    .api-layout {
        min-height: calc(100vh - 56px);
    }

    @media (min-width: 768px) {
        .api-sidebar {
            width: 280px;
            flex-shrink: 0;
            position: sticky;
            top: 56px;
            height: calc(100vh - 56px);
        }
    }
</style>
