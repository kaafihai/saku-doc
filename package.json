{
  "name": "saku-doc",
  "type": "module",
  "version": "0.0.2",
  "description": "Fast static documentation generator — OpenAPI reference, Markdown docs, and blog in one command.",
  "bin": {
    "saku-doc": "./dist/cli.js"
  },
  "files": [
    "dist/cli.js",
    "dist/src",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup lib/cli.ts",
    "develop": "tsup lib/cli.ts --watch --onSuccess \"node dist/cli.js develop -d site\"",
    "watch": "tsup lib/cli.ts --watch --onSuccess \"node dist/cli.js build -d site\""
  },
  "dependencies": {
    "@astrojs/sitemap": "3.7.1",
    "astro": "6.0.4",
    "commander": "14.0.3",
    "halfmoon": "2.0.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "22",
    "serve": "^14.2.6",
    "tsup": "8.5.1",
    "wrangler": "^4.73.0"
  }
}
